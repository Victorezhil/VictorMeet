{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(css|js|assets|public)/(.*)",
      "destination": "/$1/$2"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://victormeet.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://victormeet.onrender.com/socket.io/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
